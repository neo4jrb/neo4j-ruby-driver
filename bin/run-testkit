#!/usr/bin/env bash
#
# Run testkit against the local Ruby backend and summarise results.
#
# This is the *fast local-dev path*: the backend runs on the host under
# `bundle exec`, so iteration is sub-second and you can attach a debugger
# / profiler / IRB to the backend process directly. It is no longer the
# CI path — `.github/workflows/testkit-stub.yml` drives testkit through
# `testkit/Dockerfile` + testkit's main.py instead (the standard contract
# every official driver uses). Run that locally with:
#
#   docker build -t neo4j-ruby-driver:mri testkit/
#   TEST_DRIVER_REPO=$PWD TEST_DRIVER_NAME=ruby \
#     python3 ../testkit/main.py --tests STUB_TESTS
#
# Usage: bin/run-testkit [TEST_TARGET]
#
# TEST_TARGET defaults to "tests.neo4j" (the full integration suite).
# Pass a narrower target (e.g. "tests.neo4j.test_session_run") to iterate
# quickly on one area.
#
# Requires TESTKIT_PATH to point at a local clone of
# https://github.com/neo4j-drivers/testkit. Defaults to the project's
# sibling directory (matches the CI convention).
# A running Neo4j is required at TEST_NEO4J_HOST:TEST_NEO4J_PORT (defaults
# localhost:7687, user neo4j / pass password).

set -euo pipefail

# Default to sibling of the project (matches the CI workflow convention
# `${{ github.workspace }}/../testkit`). Works in the codespace
# (/workspaces/testkit), in CI, and in the typical local layout where
# both repos sit under one parent directory.
PROJECT_ROOT="$(cd "$(dirname "$0")/.."; pwd)"
TESTKIT_PATH="${TESTKIT_PATH:-$(dirname "$PROJECT_ROOT")/testkit}"
# Simple target: "neo4j", "stub", "tls" → discover tests/<target>/
# Dotted target: tests.neo4j.test_session_run[.TestCase[.test_method]] → specific
TEST_TARGET="${1:-neo4j}"
BACKEND_PORT="${TEST_BACKEND_PORT:-9876}"
TEST_NEO4J_HOST="${TEST_NEO4J_HOST:-localhost}"
TEST_NEO4J_USER="${TEST_NEO4J_USER:-neo4j}"
TEST_NEO4J_PASS="${TEST_NEO4J_PASS:-password}"
# test_agent_string takes the first two dot-segments of the server agent
# ("Neo4j/5.26.21" -> "Neo4j/5.26") and compares against
# "Neo4j/$TEST_NEO4J_VERSION". Set this to the 2-segment major.minor of
# whatever Neo4j you're running locally; patch number must be omitted.
TEST_NEO4J_VERSION="${TEST_NEO4J_VERSION:-2026.04}"

if [ ! -d "$TESTKIT_PATH" ]; then
  echo "testkit not found at $TESTKIT_PATH" >&2
  echo "Set TESTKIT_PATH or clone https://github.com/neo4j-drivers/testkit.git into $TESTKIT_PATH" >&2
  exit 2
fi

ARTIFACTS="$(mktemp -d -t testkit-run-XXXXXX)"
BACKEND_LOG="$ARTIFACTS/backend.log"
RUN_LOG="$ARTIFACTS/run.log"

cleanup() {
  if [ -n "${BACKEND_PID:-}" ] && kill -0 "$BACKEND_PID" 2>/dev/null; then
    kill "$BACKEND_PID" 2>/dev/null || true
    # Give the backend ~2s to shut down gracefully on SIGTERM, then SIGKILL.
    # JRuby + Netty doesn't always honor SIGTERM promptly, and a stuck
    # backend on the next run causes the EADDRINUSE / stale-port-up
    # silent-failure mode this script is meant to avoid.
    for _ in $(seq 1 20); do
      kill -0 "$BACKEND_PID" 2>/dev/null || break
      sleep 0.1
    done
    if kill -0 "$BACKEND_PID" 2>/dev/null; then
      kill -9 "$BACKEND_PID" 2>/dev/null || true
    fi
    wait "$BACKEND_PID" 2>/dev/null || true
  fi
}
trap cleanup EXIT INT TERM

# Refuse to start if something is already on the port. Without this the
# port-up poll below can be satisfied by a stale process — the new
# backend dies with EADDRINUSE but `nc -z` returns success on the first
# tick, the script proceeds, and testkit talks to the stale code.
if nc -z 127.0.0.1 "$BACKEND_PORT" 2>/dev/null; then
  echo "Port $BACKEND_PORT is already in use — kill the stale backend or set TEST_BACKEND_PORT" >&2
  if command -v lsof >/dev/null 2>&1; then
    lsof -nP -iTCP:"$BACKEND_PORT" -sTCP:LISTEN >&2 || true
  fi
  exit 4
fi

echo "-> Starting backend on port $BACKEND_PORT (log: $BACKEND_LOG)"
TEST_BACKEND_PORT="$BACKEND_PORT" \
  bundle exec ruby testkit-backend/backend.rb > "$BACKEND_LOG" 2>&1 &
BACKEND_PID=$!

# JRuby cold-start + zeitwerk eager_load can take well over the CRuby budget.
# 30s default keeps us comfortably above worst-case JRuby startup with no cost
# on the fast path (loop exits on first port-up tick).
BACKEND_BOOT_TICKS="${BACKEND_BOOT_TICKS:-300}"
PORT_UP=0
for _ in $(seq 1 "$BACKEND_BOOT_TICKS"); do
  # Liveness check first: if the backend died (e.g. EADDRINUSE from a
  # late-binding stale process, load error), surface it before trusting
  # `nc -z` — otherwise a stale port-up state masks the new-backend death.
  if ! kill -0 "$BACKEND_PID" 2>/dev/null; then
    echo "Backend process exited before binding port $BACKEND_PORT" >&2
    cat "$BACKEND_LOG" >&2
    exit 3
  fi
  if nc -z 127.0.0.1 "$BACKEND_PORT" 2>/dev/null; then
    PORT_UP=1
    break
  fi
  sleep 0.1
done

if [ "$PORT_UP" != 1 ]; then
  echo "Backend did not bind port $BACKEND_PORT within $((BACKEND_BOOT_TICKS / 10))s (PID $BACKEND_PID still alive)" >&2
  cat "$BACKEND_LOG" >&2
  exit 3
fi

if [[ "$TEST_TARGET" == *.* ]]; then
  UNITTEST_ARGS=(-v "$TEST_TARGET")
  DESCRIPTION="$TEST_TARGET"
else
  UNITTEST_ARGS=(discover -v -s "tests/$TEST_TARGET" -t .)
  DESCRIPTION="tests/$TEST_TARGET (discover)"
fi

echo "-> Running $DESCRIPTION from $TESTKIT_PATH"
set +e
(
  cd "$TESTKIT_PATH" && \
  TEST_DRIVER_NAME=ruby \
  TEST_NEO4J_HOST="$TEST_NEO4J_HOST" \
  TEST_NEO4J_USER="$TEST_NEO4J_USER" \
  TEST_NEO4J_PASS="$TEST_NEO4J_PASS" \
  TEST_NEO4J_VERSION="$TEST_NEO4J_VERSION" \
  TEST_BACKEND_PORT="$BACKEND_PORT" \
    python3 -m unittest "${UNITTEST_ARGS[@]}" 2>&1
) | tee "$RUN_LOG"
RC=${PIPESTATUS[0]}
set -e

PASS=$(grep -cE " \.\.\. ok$" "$RUN_LOG" || true)
FAIL=$(grep -cE " \.\.\. FAIL$" "$RUN_LOG" || true)
ERR=$(grep -cE " \.\.\. ERROR$" "$RUN_LOG" || true)
SKIP=$(grep -cE "skipped" "$RUN_LOG" || true)

echo
echo "================ Summary ================"
grep -E "^Ran [0-9]+ tests|^OK|^FAILED" "$RUN_LOG" | tail -n 3 || true
echo "Pass: $PASS  Fail: $FAIL  Error: $ERR  Skip: $SKIP"
echo
echo "Artifacts: $ARTIFACTS"
echo "  backend log: $BACKEND_LOG"
echo "  test log:    $RUN_LOG"

exit $RC
