#!/usr/bin/env bash
#
# Run the testkit suite locally and overwrite .github/testkit-baseline.txt
# with the list of currently-passing tests. Review `git diff` before
# committing.

set -euo pipefail

cd "$(dirname "$0")/.."

OUTPUT_TMP=$(mktemp)
trap 'rm -f "$OUTPUT_TMP"' EXIT

./bin/run-testkit neo4j > "$OUTPUT_TMP" 2>&1 || true

LOG=$(grep -oE '/tmp/testkit-run-[^ ]+|/var/folders/[^ ]*testkit-run-[^ ]+' "$OUTPUT_TMP" | tail -1)/run.log
test -f "$LOG" || { echo "no run.log produced; full output below:" >&2; cat "$OUTPUT_TMP" >&2; exit 1; }

OUT=.github/testkit-baseline.txt
{
  echo "# Tests currently expected to pass under tests/neo4j."
  echo "# CI fails if any of these stops passing (regression)."
  echo "# Add lines as we fix more; remove with reason in commit msg."
  echo "# Sorted alphabetically. Refresh with bin/refresh-testkit-baseline."
  echo ""
  grep -E ' \.\.\. ok$' "$LOG" | sed -E 's/ \.\.\. ok$//' | sort
} > "$OUT"

echo
echo "Baseline written to $OUT"
git --no-pager diff --stat "$OUT" 2>/dev/null || true
