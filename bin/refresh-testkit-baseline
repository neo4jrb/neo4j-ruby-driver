#!/usr/bin/env bash
#
# Run a testkit suite locally and overwrite the matching baseline file
# with the list of currently-passing tests. Review `git diff` before
# committing.
#
# Usage: bin/refresh-testkit-baseline [neo4j|stub]   (defaults to neo4j)

set -euo pipefail

cd "$(dirname "$0")/.."

TARGET="${1:-neo4j}"
case "$TARGET" in
  neo4j|stub) ;;
  *) echo "Unknown target: $TARGET (expected: neo4j | stub)" >&2; exit 2 ;;
esac

# Detect impl from the running Ruby; baselines are per-impl since MRI
# and JRuby flavors progress independently.
IMPL=$(ruby -e 'print RUBY_PLATFORM == "java" ? "jruby" : "mri"')

case "$TARGET" in
  neo4j) OUT=.github/testkit-baseline-${IMPL}.txt;      EXCLUDE=.github/testkit-baseline-exclude-${IMPL}.txt ;;
  stub)  OUT=.github/testkit-stub-baseline-${IMPL}.txt; EXCLUDE=.github/testkit-stub-baseline-exclude-${IMPL}.txt ;;
esac

OUTPUT_TMP=$(mktemp)
EXCLUDE_TMP=$(mktemp)
trap 'rm -f "$OUTPUT_TMP" "$EXCLUDE_TMP"' EXIT

USE_LATEST="${USE_LATEST_RUN:-0}"
if [ "$USE_LATEST" = "1" ]; then
  LOG=$(ls -td /tmp/testkit-run-*/run.log 2>/dev/null | head -1)
  test -f "$LOG" || { echo "no recent run.log"; exit 1; }
else
  ./bin/run-testkit "$TARGET" > "$OUTPUT_TMP" 2>&1 || true
fi

# bin/run-testkit prints "  test log:    <path>/run.log"; pull that line.
LOG=$(awk '/test log:/{print $NF}' "$OUTPUT_TMP" | tail -1)
test -n "$LOG" && test -f "$LOG" || {
  echo "no run.log produced (extracted path: '$LOG'); full output below:" >&2
  cat "$OUTPUT_TMP" >&2
  exit 1
}

# Build the cleaned exclusion list (one test id per line, no comments).
# `grep -v` exits 1 when the exclude file is all comments — tolerate that.
if [ -f "$EXCLUDE" ]; then
  { grep -vE '^(#|$)' "$EXCLUDE" || true; } | sort -u > "$EXCLUDE_TMP"
else
  : > "$EXCLUDE_TMP"
fi

{
  echo "# Tests currently expected to pass under tests/$TARGET on $IMPL."
  echo "# CI fails if any of these stops passing (regression)."
  echo "# Add lines as we fix more; remove with reason in commit msg."
  echo "# Sorted alphabetically. Refresh with bin/refresh-testkit-baseline $TARGET (running on $IMPL)."
  echo "# Tests known to fail in CI for env reasons live in"
  echo "# $EXCLUDE and are skipped here."
  echo ""
  # Use the same extraction the CI gate runs (canon for Python version
  # drift; ")"-suffix filter to skip unittest-docstring headers like
  # "Everything in time scenario. ... ok" that would otherwise pollute
  # the baseline; merge-line handling for output buffer races; warning-
  # split handling for nutkit's UserWarning chatter).
  # Kept inline to avoid a shared-shell-script abstraction for one
  # producer + one consumer (.github/actions/testkit-postprocess).
  awk '
    function canon(s,    op, cl, head, inner, suffix) {
      op = index(s, " (")
      if (!op) return s
      cl = length(s)
      if (substr(s, cl, 1) != ")") return s
      head = substr(s, 1, op - 1)
      inner = substr(s, op + 2, cl - op - 2)
      suffix = "." head
      if (length(inner) < length(suffix) ||
          substr(inner, length(inner) - length(suffix) + 1) != suffix) {
        return head " (" inner suffix ")"
      }
      return s
    }
    function emit_pass(s,    n, parts, i) {
      n = split(s, parts, / \.\.\. /)
      for (i = 1; i <= n; i++)
        if (parts[i] ~ /\)$/) print canon(parts[i])
    }
    / \.\.\. ok$/      { sub(/ \.\.\. ok$/, ""); emit_pass($0); pending=""; next }
    / \.\.\. FAIL$/    { pending=""; next }
    / \.\.\. ERROR$/   { pending=""; next }
    / \.\.\. skipped/  { pending=""; next }
    / \.\.\. /         { pending=$0; next }
    /^ok$/             { if (pending) { emit_pass(pending); pending="" } }
    /^FAIL$/           { pending="" }
    /^ERROR$/          { pending="" }
  ' "$LOG" \
    | sort -u \
    | comm -23 - "$EXCLUDE_TMP"
} > "$OUT"

echo
echo "Baseline written to $OUT"
git --no-pager diff --stat "$OUT" 2>/dev/null || true
